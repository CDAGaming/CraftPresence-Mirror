{
    "schema_version": 1,
    "quilt_loader": {
      "id": "${mod_id}",
      "group": "com.gitlab.cdagaming",
      "version": "${version}",
      "metadata": {
        "name": "${mod_name}",
        "description": "Completely Customize the way others see you play in Discord!",
        "contributors": {
          "CDAGaming": "Owner"
        },
        "contact": {
          "homepage": "https://www.curseforge.com/minecraft/mc-mods/craftpresence",
          "sources": "https://gitlab.com/CDAGaming/CraftPresence",
          "issues": "https://gitlab.com/CDAGaming/CraftPresence/issues"
        },
        "license": "MIT",
        "icon": "logo.png"
      },
      "intermediate_mappings": "net.fabricmc:intermediary",
      "entrypoints": {
        "client_init": "com.gitlab.cdagaming.craftpresence.quilt.CraftPresenceQuilt",
        "modmenu": "com.gitlab.cdagaming.craftpresence.quilt.impl.ModMenuImpl"
      },
      "depends": [
        {
          "id": "quilt_loader",
          "versions": "${loader_version_range}"
        },
        {
          "id": "minecraft",
          "versions": {
            "all": [
              "${game_version_range_start}",
              "${game_version_range_end}"
            ]
          }
        },
        {
          "id": "unilib",
          "versions": ">=${unilib_min_version}"
        },
        {
          "id": "java",
          "versions": ">=17"
        }
      ]
    }
  }